<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
  <meta http-equiv="Pragma" content="no-cache" />
  <meta http-equiv="Expires" content="0" />
  <meta name="theme-color" content="#2563eb" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="VolleyStat" />
  <link rel="manifest" href="manifest.json" />
  <title>VolleyStat — Live Tournament Stats</title>
  <link rel="stylesheet" href="styles.css" />
  <style>
    /* ── Segmented control ── */
    .segmented{display:inline-flex;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden}
    .seg-btn{border:0;background:transparent;padding:10px 12px;font-weight:800;letter-spacing:.02em;color:#374151;cursor:pointer;min-height:44px}
    .seg-btn[aria-pressed="true"]{background:#111827;color:#fff}
    .seg-btn:focus{outline:2px solid #60a5fa;outline-offset:2px}
    @media (max-width:1024px){.seg-btn{padding:9px 10px;font-size:12px}}

    /* ── Rotation wheel ── */
    .rotation-wheel{display:grid;grid-template-columns:repeat(3,120px);grid-template-rows:repeat(2,90px);gap:12px;justify-content:center;margin:10px 0 14px}
    .rotation-slot{border:2px solid #e5e7eb;border-radius:12px;padding:8px;text-align:center;cursor:pointer;user-select:none;background:#fff;min-height:44px;display:flex;flex-direction:column;justify-content:center}
    .rotation-slot .rot-pos{font-size:12px;color:#6b7280;font-weight:800;letter-spacing:.02em}
    .rotation-slot .rot-player{margin-top:6px;font-weight:900;color:#111827;font-size:13px;line-height:1.1}

    /* ── Modal stacking ── */
    .modal-backdrop{z-index:1000}
    #rotationBackdrop{z-index:1100}
    #pickerBackdrop{z-index:1200}

    /* ── Score tracker ── */
    .score-bar{
      background:#1e3a8a;
      padding:10px 16px;
      border-bottom:1px solid #1d4ed8;
    }
    .score-inner{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:0;
    }
    .score-team{
      display:flex;
      flex-direction:column;
      align-items:center;
      min-width:110px;
    }
    .score-team-name{
      font-size:10px;
      font-weight:800;
      color:rgba(255,255,255,.65);
      text-transform:uppercase;
      letter-spacing:.06em;
      margin-bottom:3px;
      max-width:110px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }
    .score-display{
      display:flex;
      align-items:center;
      gap:6px;
    }
    .score-num{
      font-size:40px;
      font-weight:900;
      color:#fff;
      line-height:1;
      min-width:44px;
      text-align:center;
    }
    .score-adj{
      display:flex;
      flex-direction:column;
      gap:4px;
    }
    .score-adj-btn{
      appearance:none;
      border:none;
      background:rgba(255,255,255,.18);
      color:#fff;
      width:30px;
      height:30px;
      border-radius:7px;
      font-size:18px;
      font-weight:900;
      cursor:pointer;
      display:flex;
      align-items:center;
      justify-content:center;
      line-height:1;
      padding:0;
      touch-action:manipulation;
    }
    .score-adj-btn:active{background:rgba(255,255,255,.4)}
    .score-sep{
      font-size:30px;
      font-weight:900;
      color:rgba(255,255,255,.4);
      padding:0 14px;
    }
    .score-set-label{
      text-align:center;
      font-size:10px;
      color:rgba(255,255,255,.45);
      margin-top:4px;
      letter-spacing:.04em;
    }

    /* ── Bottom nav bar ── */
    .bottom-nav{
      position:fixed;
      bottom:0;
      left:0;
      right:0;
      background:#fff;
      border-top:1px solid #e5e7eb;
      display:flex;
      z-index:900;
      padding-bottom:env(safe-area-inset-bottom, 0px);
    }
    .nav-tab{
      flex:1;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      padding:8px 4px 6px;
      border:none;
      background:transparent;
      cursor:pointer;
      color:#6b7280;
      font-size:10px;
      font-weight:700;
      gap:3px;
      min-height:56px;
      touch-action:manipulation;
      -webkit-tap-highlight-color:transparent;
    }
    .nav-tab.active{color:#2563eb}
    .nav-tab svg{width:22px;height:22px;stroke-width:2}
    .nav-tab-label{font-size:10px;font-weight:700;letter-spacing:.02em}

    /* ── Mobile panels (base — hidden by default) ── */
    .mobile-panel{display:none;padding:12px 12px 0}
    .mobile-panel.active{display:block}

    /* ── Responsive: show mobile UI on tablets and phones ── */
    @media (max-width:1024px){
      .app-header .toolbar{display:none}
      .app-main{padding-bottom:74px}
      #desktopControls{display:none}
      .score-bar{display:block}
      /* ensure active panel is visible */
      .mobile-panel.active{display:block !important}
    }
    @media (min-width:1025px){
      .bottom-nav{display:none}
      .score-bar{display:none}
      .mobile-panel{display:none !important}
    }
    .mobile-stat-group{
      background:#fff;
      border:1px solid #e5e7eb;
      border-radius:14px;
      padding:14px;
      margin-bottom:12px;
    }
    .mobile-group-title{
      font-size:11px;
      font-weight:800;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.08em;
      margin-bottom:12px;
    }
    .mobile-btn-grid{display:grid;gap:8px}
    .mobile-btn-grid.cols-3{grid-template-columns:repeat(3,1fr)}
    .mobile-btn-grid.cols-2{grid-template-columns:repeat(2,1fr)}
    .mobile-stat-btn{
      appearance:none;
      border:none;
      border-radius:14px;
      background:#2563eb;
      color:#fff;
      font-weight:900;
      font-size:16px;
      min-height:68px;
      cursor:pointer;
      touch-action:manipulation;
      -webkit-tap-highlight-color:transparent;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:8px 6px;
      text-align:center;
      line-height:1.15;
      transition:background .08s,transform .06s;
      box-shadow:0 3px 8px rgba(37,99,235,.2);
    }
    .mobile-stat-btn:active{background:#1d4ed8;transform:scale(.95);box-shadow:none}
    .mobile-stat-btn.danger{background:#dc2626;box-shadow:0 3px 8px rgba(220,38,38,.2)}
    .mobile-stat-btn.danger:active{background:#b91c1c}
    .mobile-stat-btn:disabled{background:#94a3b8;box-shadow:none;cursor:not-allowed}

    /* ── Mobile controls section ── */
    .mobile-controls-section{
      background:#fff;
      border:1px solid #e5e7eb;
      border-radius:14px;
      padding:14px;
      margin-bottom:12px;
    }
    .mobile-controls-section .control{margin-bottom:10px}
    .mobile-controls-section .control:last-child{margin-bottom:0}
    .mobile-controls-section label{font-size:11px;font-weight:800;color:#6b7280;text-transform:uppercase;letter-spacing:.07em;display:block;margin-bottom:5px}
    .mobile-controls-section select,.mobile-export-row input{
      width:100%;
      border:1px solid #e5e7eb;
      border-radius:10px;
      padding:11px 10px;
      font-weight:700;
      background:#fff;
      font-size:14px;
    }
    .mobile-export-row{display:flex;flex-direction:column;gap:10px}
    .mobile-export-row .btn{width:100%;justify-content:center;min-height:48px;font-size:14px}

    /* ── Tap flash ── */
    @keyframes tapFlash{0%{opacity:1}50%{opacity:.5}100%{opacity:1}}
    .tap-flash{animation:tapFlash .15s ease}

    /* ── Install banner ── */
    #installBanner{
      display:none;
      background:#1e3a8a;
      color:#fff;
      padding:10px 14px;
      font-size:13px;
      font-weight:700;
      align-items:center;
      justify-content:space-between;
      gap:8px;
    }
    #installBanner.visible{display:flex}
    #installBannerBtn{
      background:#fff;
      color:#1e3a8a;
      border:none;
      border-radius:8px;
      padding:7px 14px;
      font-weight:800;
      font-size:12px;
      cursor:pointer;
      white-space:nowrap;
      min-height:34px;
    }
    #installBannerDismiss{
      background:transparent;
      border:none;
      color:rgba(255,255,255,.7);
      font-size:20px;
      cursor:pointer;
      padding:0 4px;
      line-height:1;
    }
  </style>
</head>
<body>

  <!-- PWA install banner -->
  <div id="installBanner">
    <span>📲 Add VolleyStat to your home screen</span>
    <button id="installBannerBtn">Install</button>
    <button id="installBannerDismiss" aria-label="Dismiss">✕</button>
  </div>

  <header class="app-header">
    <div class="title-wrap">
      <h1>LIVE Courtside Volleyball Stat App</h1>
      <div class="version">Version Alpha 0.1.9</div>
    </div>

    <!-- Desktop toolbar (hidden on mobile) -->
    <div class="toolbar">
      <div class="group">
        <div class="group-title">SERVING</div>
        <div class="btn-row">
          <button class="btn" data-action="serve1"><span class="btn-text">1</span></button>
          <button class="btn" data-action="serve2"><span class="btn-text">2</span></button>
          <button class="btn" data-action="serve3"><span class="btn-text">3</span></button>
          <button class="btn" data-action="ace"><span class="btn-text">ACE</span></button>
          <button type="button" class="btn danger" data-action="serveOut"><span class="btn-text">OUT</span></button>
        </div>
      </div>
      <div class="divider"></div>
      <div class="group">
        <div class="group-title">SERVE/REC</div>
        <div class="btn-row">
          <button class="btn" data-action="passToTarget" title="3"><span class="btn-text">3</span></button>
          <button class="btn" data-action="passNearTarget" title="2"><span class="btn-text">2</span></button>
          <button class="btn" data-action="passAwayTarget" title="1"><span class="btn-text">1</span></button>
          <button class="btn" data-action="passShank" title="0"><span class="btn-text">0</span></button>
        </div>
      </div>
      <div class="divider"></div>
      <div class="group">
        <div class="group-title">ATTACKING</div>
        <div class="btn-row">
          <button class="btn" data-action="swing"><span class="btn-text">Swing</span></button>
          <button class="btn" data-action="swingOut"><span class="btn-text">Swing Out</span></button>
          <button class="btn" data-action="kill"><span class="btn-text">Kill</span></button>
        </div>
      </div>
      <div class="divider"></div>
      <div class="group">
        <div class="group-title">ERRORS (manual)</div>
        <div class="btn-row">
          <button type="button" class="btn danger" data-action="errPassing"><span class="btn-text">Pass Err</span></button>
          <button type="button" class="btn danger" data-action="errNet"><span class="btn-text">Net</span></button>
          <button type="button" class="btn danger" data-action="errTwoHand"><span class="btn-text">2-Hand</span></button>
          <button type="button" class="btn danger" data-action="errRotation"><span class="btn-text">OOR</span></button>
        </div>
      </div>
    </div>
  </header>

  <!-- Live score bar (mobile only) -->
  <div class="score-bar" id="scoreBar">
    <div class="score-inner">
      <div class="score-team">
        <div class="score-team-name" id="scoreTeamName">Your Team</div>
        <div class="score-display">
          <div class="score-adj">
            <button class="score-adj-btn" id="ourScoreUp" aria-label="Increase our score">+</button>
            <button class="score-adj-btn" id="ourScoreDown" aria-label="Decrease our score">−</button>
          </div>
          <div class="score-num" id="ourScore">0</div>
        </div>
      </div>
      <div class="score-sep">:</div>
      <div class="score-team">
        <div class="score-team-name" style="opacity:0">opp</div>
        <div class="score-display">
          <div class="score-num" id="oppScore">0</div>
          <div class="score-adj">
            <button class="score-adj-btn" id="oppScoreUp" aria-label="Increase opponent score">+</button>
            <button class="score-adj-btn" id="oppScoreDown" aria-label="Decrease opponent score">−</button>
          </div>
        </div>
      </div>
    </div>
    <div class="score-set-label" id="scoreSetLabel">Set 1</div>
  </div>

  <main class="app-main">

    <!-- ── Mobile panel: Track ── -->
    <div id="mobileTrackPanel" class="mobile-panel active">
      <div class="mobile-controls-section">
        <div class="control">
          <label>Player</label>
          <select id="mobilePlayerSelect"><option value="">— select player —</option></select>
        </div>
        <div style="display:flex;gap:8px;align-items:center">
          <button id="mobileUndoBtn" type="button" class="btn secondary" style="min-height:44px;flex:1">Undo Last</button>
          <div id="mobileRotationBtnWrap" style="display:none;flex:1">
            <button id="mobileRotationBtn" type="button" class="btn secondary" style="min-height:44px;width:100%">Rotation</button>
          </div>
        </div>
      </div>

      <div class="mobile-stat-group">
        <div class="mobile-group-title">Serving</div>
        <div class="mobile-btn-grid cols-3">
          <button class="mobile-stat-btn" data-action="serve1">1</button>
          <button class="mobile-stat-btn" data-action="serve2">2</button>
          <button class="mobile-stat-btn" data-action="serve3">3</button>
          <button class="mobile-stat-btn" data-action="ace">ACE</button>
          <button class="mobile-stat-btn danger" data-action="serveOut" style="grid-column:span 2">OUT</button>
        </div>
      </div>

      <div class="mobile-stat-group">
        <div class="mobile-group-title">Serve / Receive</div>
        <div class="mobile-btn-grid cols-2">
          <button class="mobile-stat-btn" data-action="passToTarget">3 — Perfect</button>
          <button class="mobile-stat-btn" data-action="passNearTarget">2 — Good</button>
          <button class="mobile-stat-btn" data-action="passAwayTarget">1 — Poor</button>
          <button class="mobile-stat-btn danger" data-action="passShank">0 — Shank</button>
        </div>
      </div>

      <div class="mobile-stat-group">
        <div class="mobile-group-title">Attacking</div>
        <div class="mobile-btn-grid cols-2">
          <button class="mobile-stat-btn" data-action="kill">Kill</button>
          <button class="mobile-stat-btn" data-action="swing">Swing</button>
          <button class="mobile-stat-btn danger" data-action="swingOut" style="grid-column:span 2">Swing Out / Error</button>
        </div>
      </div>

      <div class="mobile-stat-group">
        <div class="mobile-group-title">Unforced Errors</div>
        <p style="font-size:12px;color:#6b7280;margin:0 0 10px;line-height:1.5;">Hit, Serve, and Pass (SR) errors are counted automatically from Swing Out, Serve Out, and Pass 0. Use these for additional errors:</p>
        <div class="mobile-btn-grid cols-2">
          <button class="mobile-stat-btn danger" data-action="errPassing" style="grid-column:span 2">Passing Error <span style="font-size:11px;opacity:.8;display:block">(not in serve receive)</span></button>
          <button class="mobile-stat-btn danger" data-action="errNet">In the Net</button>
          <button class="mobile-stat-btn danger" data-action="errTwoHand">Two Hand</button>
          <button class="mobile-stat-btn danger" data-action="errRotation" style="grid-column:span 2">Out of Rotation</button>
        </div>
      </div>
    </div>

    <!-- ── Mobile panel: Settings ── -->
    <div id="mobileStatsPanel" class="mobile-panel">
      <div class="mobile-controls-section">
        <div class="control">
          <label>Team</label>
          <div style="display:flex;gap:8px">
            <select id="mobileTeamSelect" style="flex:1"></select>
            <button id="mobileTeamsBtn" type="button" class="btn secondary" style="white-space:nowrap;min-height:44px">Teams</button>
          </div>
        </div>
        <div class="control">
          <label>Match</label>
          <select id="mobileMatchSelect"></select>
        </div>
        <div style="display:flex;gap:10px">
          <div class="control" style="flex:1">
            <label>Set</label>
            <select id="mobileSetSelect">
              <option value="1">Set 1</option>
              <option value="2">Set 2</option>
              <option value="3">Set 3</option>
            </select>
          </div>
          <div class="control" style="flex:1">
            <label>View</label>
            <select id="mobileViewSelect">
              <option value="set">Current Set</option>
              <option value="match">Current Match</option>
              <option value="tournament" selected>Tournament Total</option>
            </select>
          </div>
        </div>
        <div class="control">
          <label>Mode</label>
          <div id="mobileModeToggle" class="segmented" role="group" aria-label="Stats mode" style="width:100%">
            <button id="mobileModePlayer" type="button" class="seg-btn" aria-pressed="true" style="flex:1">Player View</button>
            <button id="mobileModeCoach" type="button" class="seg-btn" aria-pressed="false" style="flex:1">Coach View</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Mobile panel: Roster ── -->
    <div id="mobileRosterPanel" class="mobile-panel">
      <div class="mobile-controls-section">
        <p style="color:#6b7280;font-size:13px;margin:0 0 12px">Add players to your team roster. They'll appear in the Track tab for stat entry.</p>
        <button id="mobileRosterBtn" type="button" class="btn" style="width:100%;justify-content:center;min-height:52px;font-size:15px">Open Roster Manager</button>
      </div>
    </div>

    <!-- ── Mobile panel: Export ── -->
    <div id="mobileExportPanel" class="mobile-panel">
      <div class="mobile-controls-section">
        <div class="mobile-export-row">
          <input id="mobileExportName" placeholder="Export name (optional)" style="font-weight:700" />
          <button id="mobileExportBtn" type="button" class="btn" style="justify-content:center;min-height:52px;font-size:15px">Export CSV</button>
          <button id="mobileResetBtn" type="button" class="btn danger" style="justify-content:center;min-height:52px;font-size:15px">Reset Stats</button>
        </div>
      </div>
    </div>

    <!-- ── Desktop controls (hidden on mobile) ── -->
    <section class="controls" id="desktopControls">
      <div class="control"><label>Team</label><select id="teamSelect"></select></div>
      <div class="control"><label> </label><div class="control-row"><button id="teamsBtn" type="button" class="btn secondary">Teams</button></div></div>
      <div class="control"><label>Match</label><select id="matchSelect"></select></div>
      <div class="control"><label>Set</label>
        <select id="setSelect"><option value="1">Set 1</option><option value="2">Set 2</option><option value="3">Set 3</option></select>
      </div>
      <div class="control"><label>View</label>
        <select id="viewSelect"><option value="set">Current Set</option><option value="match">Current Match</option><option value="tournament" selected>Tournament Total</option></select>
      </div>
      <div class="control"><label>Mode</label>
        <div id="modeToggle" class="segmented" role="group" aria-label="Stats mode">
          <button id="modePlayer" type="button" class="seg-btn" aria-pressed="true">Player View</button>
          <button id="modeCoach" type="button" class="seg-btn" aria-pressed="false">Coach View</button>
        </div>
      </div>
      <div class="control grow"><label> </label>
        <div class="control-row" style="flex-wrap:wrap;gap:10px;">
          <button id="rosterBtn" type="button" class="btn secondary">Roster</button>
          <button id="undoBtn" type="button" class="btn secondary">Undo</button>
          <div class="export-wrap"><input id="exportName" class="export-name" placeholder="Export name (optional)" />
            <button id="exportBtn" type="button" class="btn secondary">Export CSV</button>
          </div>
          <button id="rotationBtn" type="button" class="btn secondary" style="display:none">Rotation</button>
          <button id="resetBtn" type="button" class="btn danger">Reset</button>
        </div>
      </div>
    </section>

    <section id="onboarding" class="onboarding hidden" aria-live="polite">
      <div class="onboarding-card">
        <div class="onboarding-title" id="onboardingTitle">Get started</div>
        <div class="onboarding-sub" id="onboardingSub">Create a team, then add your roster.</div>
        <ol class="onboarding-steps">
          <li><strong>Add a Team</strong> (Teams → New → Save Team)</li>
          <li><strong>Add a Roster</strong> (Roster → Add Player → Save Player)</li>
        </ol>
        <div class="onboarding-actions">
          <button id="onboardingTeamsBtn" type="button" class="btn">Add Team</button>
          <button id="onboardingRosterBtn" type="button" class="btn secondary">Add Roster</button>
        </div>
      </div>
    </section>

    <section class="table-wrap">
      <table id="statsTable">
        <thead>
          <tr>
            <th class="sticky-col left">Player</th>
            <th id="thServeAtt">Serve Att</th>
            <th id="thServeIn">Serves In</th>
            <th id="thPressure" class="left" style="text-align:right;">
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
                <div id="pressureLabel">Serve In%</div>
                <div style="width:110px;height:6px;border-radius:999px;background:linear-gradient(90deg,hsl(120 75% 85%),hsl(60 75% 80%),hsl(0 75% 70%));"></div>
                <div style="width:110px;display:flex;justify-content:space-between;font-size:10px;color:#6b7280;font-weight:800;letter-spacing:.02em;">
                  <span>Easy</span><span>Pressure</span>
                </div>
              </div>
            </th>
            <th id="thAces">ACE</th>
            <th id="thAcePct">Ace%</th>
            <th id="thPassAtt">Pass Att</th>
            <th id="thPassAvg">Pass Avg</th>
            <th>Hit Att</th>
            <th>Hit Avg</th>
            <th>Hits In</th>
            <th>Hits In%</th>
            <th style="border-left:2px solid #e5e7eb">Errors</th>
            <th>Hit Err</th>
            <th>Srv Err</th>
            <th>Pass Err</th>
            <th>Net</th>
            <th>2-Hand</th>
            <th>OOR</th>
          </tr>
        </thead>
        <tbody id="statsBody"></tbody>
      </table>
      <div id="hintText" class="hint">Pressure% = (3 + ACE) ÷ Serve Attempts. Serving buttons reflect opponent pass: 1 (opp 3) → 3 (opp 1) → ACE (0). OUT counts as a serve attempt but not an opponent reception attempt.</div>
    </section>
  </main>

  <!-- Bottom nav (mobile only) -->
  <nav class="bottom-nav" id="bottomNav" aria-label="App navigation">
    <button class="nav-tab active" data-panel="mobileTrackPanel" aria-label="Track stats">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
      <span class="nav-tab-label">Track</span>
    </button>
    <button class="nav-tab" data-panel="mobileStatsPanel" aria-label="Settings">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M4.93 4.93l1.41 1.41M4.93 19.07l1.41-1.41M19.07 19.07l-1.41-1.41M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
      <span class="nav-tab-label">Settings</span>
    </button>
    <button class="nav-tab" data-panel="mobileRosterPanel" aria-label="Roster">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <span class="nav-tab-label">Roster</span>
    </button>
    <button class="nav-tab" data-panel="mobileExportPanel" aria-label="Export">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      <span class="nav-tab-label">Export</span>
    </button>
  </nav>

  <!-- ── Modals (unchanged from original) ── -->
  <div id="pickerBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="pickerTitle">Select Player</div>
        <button id="pickerClose" type="button" class="icon-btn" aria-label="Close">✕</button>
      </div>
      <div class="modal-body"><div id="playerGrid" class="player-grid"></div></div>
      <div class="modal-footer"><button id="pickerCancel" type="button" class="btn secondary">Cancel</button></div>
    </div>
  </div>

  <div id="rosterBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true">
    <div class="modal">
      <div class="modal-header"><div class="modal-title">Roster</div><button id="rosterClose" type="button" class="icon-btn" aria-label="Close">✕</button></div>
      <div class="modal-body">
        <form id="playerForm" class="form">
          <input type="hidden" id="playerId" />
          <div class="form-row">
            <div class="field"><label>Player Name</label><input id="playerName" placeholder="e.g., Caroline Gasset" required /></div>
            <div class="field small"><label>Jersey #</label><input id="playerNumber" placeholder="e.g., 12" inputmode="numeric" /></div>
            <div class="field small"><label>Position</label><input id="playerPos" placeholder="e.g., S / OH1 / MB2 / RS / OH2 / MB1" /></div>
          </div>
          <div class="form-actions"><button type="submit" class="btn">Save Player</button><button type="button" id="newPlayerBtn" class="btn secondary">New</button></div>
        </form>
        <div class="roster-list-wrap"><div class="roster-list-title">Current Roster</div><div id="rosterList" class="roster-list"></div></div>
      </div>
      <div class="modal-footer"><button id="rosterDone" type="button" class="btn secondary">Done</button></div>
    </div>
  </div>

  <div id="teamsBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true">
    <div class="modal">
      <div class="modal-header"><div class="modal-title">Teams</div><button id="teamsClose" type="button" class="icon-btn" aria-label="Close">✕</button></div>
      <div class="modal-body">
        <form id="teamForm" class="form">
          <input type="hidden" id="teamId" />
          <div class="form-row"><div class="field"><label>Team Name</label><input id="teamName" placeholder="e.g., 575 16s National" required /></div></div>
          <div class="form-actions">
            <button type="submit" class="btn">Save Team</button>
            <button type="button" id="newTeamBtn" class="btn secondary">New</button>
            <button type="button" id="exportTeamBtn" class="btn secondary">Export Team</button>
            <button type="button" id="importTeamBtn" class="btn secondary">Import Team</button>
            <input id="importTeamInput" type="file" accept="application/json" style="display:none" />
          </div>
        </form>
        <div class="roster-list-wrap"><div class="roster-list-title">Your Teams (local to this device)</div><div id="teamsList" class="roster-list"></div></div>
      </div>
      <div class="modal-footer"><button id="teamsDone" type="button" class="btn secondary">Done</button></div>
    </div>
  </div>

  <div id="rotationBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true">
    <div class="modal">
      <div class="modal-header"><div class="modal-title">Rotation (Coach)</div><button id="rotationClose" type="button" class="icon-btn" aria-label="Close">✕</button></div>
      <div class="modal-body">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin:6px 0 10px;">
          <div>
            <label style="font-weight:900;color:#374151;font-size:12px;">Setter Position</label>
            <select id="setterPosSelect" style="margin-left:8px;">
              <option value="">—</option>
              <option value="1">1</option><option value="2">2</option><option value="3">3</option>
              <option value="4">4</option><option value="5">5</option><option value="6">6</option>
            </select>
          </div>
          <div class="hint" style="margin:0;">Server = Pos 1 (auto)</div>
        </div>
        <div id="rotationWheel" class="rotation-wheel" aria-label="Rotation wheel"></div>
        <div class="hint" style="margin-top:6px;">Tap a position to assign a player. (Pos 1 is the server.)</div>
      </div>
      <div class="modal-footer"><button id="rotationClear" type="button" class="btn secondary">Clear</button><button id="rotationDone" type="button" class="btn">Done</button></div>
    </div>
  </div>

  <div id="exportConfirmBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true" aria-labelledby="exportConfirmTitle">
    <div class="modal">
      <div class="modal-header"><div class="modal-title" id="exportConfirmTitle">Confirm Export</div><button id="exportConfirmClose" type="button" class="icon-btn" aria-label="Close">✕</button></div>
      <div class="modal-body">
        <div class="confirm-grid">
          <div class="confirm-row"><div class="confirm-label">File</div><div id="exportConfirmFile" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">Team</div><div id="exportConfirmTeam" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">View</div><div id="exportConfirmView" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">Scope</div><div id="exportConfirmScope" class="confirm-value"></div></div>
        </div>
        <div class="confirm-note">Select "Export" to download, or "Cancel" to abort.</div>
      </div>
      <div class="modal-footer"><button id="exportConfirmCancel" type="button" class="btn secondary">Cancel</button><button id="exportConfirmOk" type="button" class="btn">Export</button></div>
    </div>
  </div>

  <div id="resetConfirmBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true" aria-labelledby="resetConfirmTitle">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="resetConfirmTitle">Confirm Reset</div>
        <button id="resetConfirmClose" type="button" class="icon-btn" aria-label="Close">✕</button>
      </div>
      <div class="modal-body">
        <div class="confirm-grid">
          <div class="confirm-row"><div class="confirm-label">Team</div><div id="resetConfirmTeam" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">What resets</div><div id="resetConfirmScope" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">Rotation</div><div id="resetConfirmRotation" class="confirm-value"></div></div>
        </div>
        <div class="confirm-note" style="margin-top:10px;"><strong>Reminder:</strong> Export CSV first if you want to keep a copy of your stats.</div>
      </div>
      <div class="modal-footer" style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
        <button id="resetConfirmExport" type="button" class="btn secondary">Export CSV</button>
        <button id="resetConfirmCancel" type="button" class="btn secondary">Cancel</button>
        <button id="resetConfirmOk" type="button" class="btn danger">Reset Stats</button>
      </div>
    </div>
  </div>

  <script src="app.js?v=0.1.9"></script>
</body>
</html>
