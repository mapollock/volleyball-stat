<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
  <meta http-equiv="Pragma" content="no-cache" />
  <meta http-equiv="Expires" content="0" />
  <title>VolleyStat — Live Tournament Stats</title>
  <link rel="stylesheet" href="styles.css" />
  <style>
    .segmented{display:inline-flex;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden}
    .seg-btn{border:0;background:transparent;padding:10px 12px;font-weight:800;letter-spacing:.02em;color:#374151;cursor:pointer}
    .seg-btn[aria-pressed="true"]{background:#111827;color:#fff}
    .seg-btn:focus{outline:2px solid #60a5fa;outline-offset:2px}
    @media (max-width:720px){.seg-btn{padding:9px 10px;font-size:12px}}

    /* Rotation wheel (Coach View) */
    .rotation-wheel{display:grid;grid-template-columns:repeat(3,120px);grid-template-rows:repeat(2,90px);gap:12px;justify-content:center;margin:10px 0 14px}
    .rotation-slot{border:2px solid #e5e7eb;border-radius:12px;padding:8px;text-align:center;cursor:pointer;user-select:none;background:#fff}
    .rotation-slot .rot-pos{font-size:12px;color:#6b7280;font-weight:800;letter-spacing:.02em}
    .rotation-slot .rot-player{margin-top:6px;font-weight:900;color:#111827;font-size:13px;line-height:1.1}

    /* Modal stacking order */
    .modal-backdrop{z-index:1000}
    #rotationBackdrop{z-index:1100}
    #pickerBackdrop{z-index:1200}
  </style>
</head>
<body>
  <header class="app-header">
    <div class="title-wrap">
      <h1>LIVE Courtside Volleyball Stat App</h1>
      <div class="version">Version Alpha 0.1.7.5</div>
    </div>

    <div class="toolbar">
      <div class="group">
        <div class="group-title">SERVING</div>
        <div class="btn-row">
          <button class="btn" data-action="serve1"><span class="btn-text">1</span></button>
          <button class="btn" data-action="serve2"><span class="btn-text">2</span></button>
          <button class="btn" data-action="serve3"><span class="btn-text">3</span></button>
          <button class="btn" data-action="ace"><span class="btn-text">ACE</span></button>
          <button type="button" class="btn danger" data-action="serveOut"><span class="btn-text">OUT</span></button>
        </div>
      </div>
      <div class="divider"></div>
      <div class="group">
        <div class="group-title">SERVE/REC</div>
        <div class="btn-row">
          <button class="btn" data-action="passToTarget" title="3"><span class="btn-text">3</span></button>
          <button class="btn" data-action="passNearTarget" title="2"><span class="btn-text">2</span></button>
          <button class="btn" data-action="passAwayTarget" title="1"><span class="btn-text">1</span></button>
          <button class="btn" data-action="passShank" title="0"><span class="btn-text">0</span></button>
        </div>
      </div>
      <div class="divider"></div>
      <div class="group">
        <div class="group-title">ATTACKING</div>
        <div class="btn-row">
          <button class="btn" data-action="swing" title="Swing"><span class="btn-text">Swing</span></button>
          <button class="btn" data-action="swingOut" title="Swing Out"><span class="btn-text">Swing Out</span></button>
          <button class="btn" data-action="kill" title="Kill"><span class="btn-text">Kill</span></button>
          <button class="btn" data-action="tip" title="Tip"><span class="btn-text">Tip</span></button>
          <button class="btn" data-action="tipKill" title="Tip Kill"><span class="btn-text">Tip Kill</span></button>
        </div>
      </div>
    </div>
  </header>

  <main class="app-main">
    <section class="controls">
      <div class="control"><label>Team</label><select id="teamSelect"></select></div>
      <div class="control"><label> </label><div class="control-row"><button id="teamsBtn" type="button" class="btn secondary">Teams</button></div></div>
      <div class="control"><label>Match</label><select id="matchSelect"></select></div>
      <div class="control"><label>Set</label>
        <select id="setSelect"><option value="1">Set 1</option><option value="2">Set 2</option><option value="3">Set 3</option></select>
      </div>
      <div class="control"><label>View</label>
        <select id="viewSelect"><option value="set">Current Set</option><option value="match">Current Match</option><option value="tournament" selected>Tournament Total</option></select>
      </div>
      <div class="control"><label>Mode</label>
        <div id="modeToggle" class="segmented" role="group" aria-label="Stats mode">
          <button id="modePlayer" type="button" class="seg-btn" aria-pressed="true">Player View</button>
          <button id="modeCoach" type="button" class="seg-btn" aria-pressed="false">Coach View</button>
        </div>
      </div>
      <div class="control grow"><label> </label>
        <div class="control-row" style="flex-wrap:wrap;gap:10px;">
          <button id="rosterBtn" type="button" class="btn secondary">Roster</button>
          <button id="undoBtn" type="button" class="btn secondary">Undo</button>
          <div class="export-wrap"><input id="exportName" class="export-name" placeholder="Export name (optional)" />
            <button id="exportBtn" type="button" class="btn secondary">Export CSV</button>
          </div>
          <button id="rotationBtn" type="button" class="btn secondary" style="display:none">Rotation</button>
          <button id="resetBtn" type="button" class="btn danger">Reset</button>
        </div>
      </div>
    </section>

    <section id="onboarding" class="onboarding hidden" aria-live="polite">
      <div class="onboarding-card">
        <div class="onboarding-title" id="onboardingTitle">Get started</div>
        <div class="onboarding-sub" id="onboardingSub">Create a team, then add your roster.</div>
        <ol class="onboarding-steps">
          <li><strong>Add a Team</strong> (Teams → New → Save Team)</li>
          <li><strong>Add a Roster</strong> (Roster → Add Player → Save Player)</li>
        </ol>
        <div class="onboarding-actions">
          <button id="onboardingTeamsBtn" type="button" class="btn">Add Team</button>
          <button id="onboardingRosterBtn" type="button" class="btn secondary">Add Roster</button>
        </div>
      </div>
    </section>

    <section class="table-wrap">
      <table id="statsTable">
        <thead>
          <tr>
            <th class="sticky-col left">#</th>
            <th class="left">Player</th>
            <th class="left">Pos</th>
            <th id="thServeAtt">Serve Att</th>
            <th id="thServeAvg">Serve Avg</th>
            <th id="thPressure" class="left" style="text-align:right;">
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
                <div id="pressureLabel">Pressure%</div>
                <div style="width:110px;height:6px;border-radius:999px;background:linear-gradient(90deg,hsl(120 75% 85%),hsl(60 75% 80%),hsl(0 75% 70%));"></div>
                <div style="width:110px;display:flex;justify-content:space-between;font-size:10px;color:#6b7280;font-weight:800;letter-spacing:.02em;">
                  <span>Easy</span><span>Pressure</span>
                </div>
              </div>
            </th>
            <th id="thAces">ACE</th>
            <th id="thAcePct">Ace%</th>
            <th id="thPassAtt">Pass Att</th>
            <th id="thPassAvg">Pass Avg</th>
            <th>Hit Att</th>
            <th>Hit Avg</th>
            <th>Kills</th>
            <th>Kill%</th>
          </tr>
        </thead>
        <tbody id="statsBody"></tbody>
      </table>

      <div id="hintText" class="hint">Pressure% = (3 + ACE) ÷ Serve Attempts. Serving buttons reflect opponent pass: 1 (opp 3) → 3 (opp 1) → ACE (0). OUT counts as a serve attempt but not an opponent reception attempt.</div>
    </section>
  </main>

  <div id="pickerBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="pickerTitle">Select Player</div>
        <button id="pickerClose" type="button" class="icon-btn" aria-label="Close">✕</button>
      </div>
      <div class="modal-body"><div id="playerGrid" class="player-grid"></div></div>
      <div class="modal-footer"><button id="pickerCancel" type="button" class="btn secondary">Cancel</button></div>
    </div>
  </div>

  <div id="rosterBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true">
    <div class="modal">
      <div class="modal-header"><div class="modal-title">Roster</div><button id="rosterClose" type="button" class="icon-btn" aria-label="Close">✕</button></div>
      <div class="modal-body">
        <form id="playerForm" class="form">
          <input type="hidden" id="playerId" />
          <div class="form-row">
            <div class="field"><label>Player Name</label><input id="playerName" placeholder="e.g., Caroline Gasset" required /></div>
            <div class="field small"><label>Jersey #</label><input id="playerNumber" placeholder="e.g., 12" inputmode="numeric" /></div>
            <div class="field small"><label>Position</label><input id="playerPos" placeholder="e.g., S / OH1 / MB2 / RS / OH2 / MB1" /></div>
          </div>
          <div class="form-actions"><button type="submit" class="btn">Save Player</button><button type="button" id="newPlayerBtn" class="btn secondary">New</button></div>
        </form>
        <div class="roster-list-wrap"><div class="roster-list-title">Current Roster</div><div id="rosterList" class="roster-list"></div></div>
      </div>
      <div class="modal-footer"><button id="rosterDone" type="button" class="btn secondary">Done</button></div>
    </div>
  </div>

  <div id="teamsBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true">
    <div class="modal">
      <div class="modal-header"><div class="modal-title">Teams</div><button id="teamsClose" type="button" class="icon-btn" aria-label="Close">✕</button></div>
      <div class="modal-body">
        <form id="teamForm" class="form">
          <input type="hidden" id="teamId" />
          <div class="form-row"><div class="field"><label>Team Name</label><input id="teamName" placeholder="e.g., 575 16s National" required /></div></div>
          <div class="form-actions">
            <button type="submit" class="btn">Save Team</button>
            <button type="button" id="newTeamBtn" class="btn secondary">New</button>
            <button type="button" id="exportTeamBtn" class="btn secondary">Export Team</button>
            <button type="button" id="importTeamBtn" class="btn secondary">Import Team</button>
            <input id="importTeamInput" type="file" accept="application/json" style="display:none" />
          </div>
        </form>
        <div class="roster-list-wrap"><div class="roster-list-title">Your Teams (local to this device)</div><div id="teamsList" class="roster-list"></div></div>
      </div>
      <div class="modal-footer"><button id="teamsDone" type="button" class="btn secondary">Done</button></div>
    </div>
  </div>

  <div id="rotationBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true">
    <div class="modal">
      <div class="modal-header"><div class="modal-title">Rotation (Coach)</div><button id="rotationClose" type="button" class="icon-btn" aria-label="Close">✕</button></div>
      <div class="modal-body">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin:6px 0 10px;">
          <div>
            <label style="font-weight:900;color:#374151;font-size:12px;">Setter Position</label>
            <select id="setterPosSelect" class="input" style="margin-left:8px;">
              <option value="">—</option>
              <option value="1">1</option><option value="2">2</option><option value="3">3</option>
              <option value="4">4</option><option value="5">5</option><option value="6">6</option>
            </select>
          </div>
          <div class="hint" style="margin:0;">Server = Pos 1 (auto)</div>
        </div>
        <div id="rotationWheel" class="rotation-wheel" aria-label="Rotation wheel"></div>
        <div class="hint" style="margin-top:6px;">Tap a position to assign a player. (Pos 1 is the server.)</div>
      </div>
      <div class="modal-footer"><button id="rotationClear" type="button" class="btn secondary">Clear</button><button id="rotationDone" type="button" class="btn">Done</button></div>
    </div>
  </div>

  <div id="exportConfirmBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true" aria-labelledby="exportConfirmTitle">
    <div class="modal">
      <div class="modal-header"><div class="modal-title" id="exportConfirmTitle">Confirm Export</div><button id="exportConfirmClose" type="button" class="icon-btn" aria-label="Close">✕</button></div>
      <div class="modal-body">
        <div class="confirm-grid">
          <div class="confirm-row"><div class="confirm-label">File</div><div id="exportConfirmFile" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">Team</div><div id="exportConfirmTeam" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">View</div><div id="exportConfirmView" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">Scope</div><div id="exportConfirmScope" class="confirm-value"></div></div>
        </div>
        <div class="confirm-note">Select “Export” to download, or “Cancel” to abort.</div>
      </div>
      <div class="modal-footer"><button id="exportConfirmCancel" type="button" class="btn secondary">Cancel</button><button id="exportConfirmOk" type="button" class="btn">Export</button></div>
    </div>
  </div>

  <div id="resetConfirmBackdrop" class="modal-backdrop hidden" style="display:none" role="dialog" aria-modal="true" aria-labelledby="resetConfirmTitle">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="resetConfirmTitle">Confirm Reset</div>
        <button id="resetConfirmClose" type="button" class="icon-btn" aria-label="Close">✕</button>
      </div>
      <div class="modal-body">
        <div class="confirm-grid">
          <div class="confirm-row"><div class="confirm-label">Team</div><div id="resetConfirmTeam" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">What resets</div><div id="resetConfirmScope" class="confirm-value"></div></div>
          <div class="confirm-row"><div class="confirm-label">Rotation</div><div id="resetConfirmRotation" class="confirm-value"></div></div>
        </div>
        <div class="confirm-note" style="margin-top:10px;"><strong>Reminder:</strong> Export CSV first if you want to keep a copy of your stats.</div>
      </div>
      <div class="modal-footer" style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
        <button id="resetConfirmExport" type="button" class="btn secondary">Export CSV</button>
        <button id="resetConfirmCancel" type="button" class="btn secondary">Cancel</button>
        <button id="resetConfirmOk" type="button" class="btn danger">Reset Stats</button>
      </div>
    </div>
  </div>



  <script src="app.js?v=0.1.7.5"></script>
</body>
</html>
